graph TD
    subgraph PAGES["Next.js Pages"]
        AUTH_P["Auth Pages\n/login /signup /forgot-password"]
        ADMIN_P["Admin Dashboard\n/dashboard/admin"]
        WH_P["Warehouse Dashboard\n/dashboard/warehouse"]
        PROC_P["Procurement Dashboard\n/dashboard/procurement"]
        DEV_P["Dev Tools\n/dashboard/dev-tools/agent-monitor"]
    end

    PR["ProtectedRoute\nchecks isAuthenticated + role"]

    subgraph STATE["State Management"]
