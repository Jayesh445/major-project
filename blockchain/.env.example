# Copy this file to .env and fill in your values

# Alchemy or Infura Sepolia RPC URL
# Get a free one at: https://www.alchemy.com (create app -> Sepolia network)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Private key of the deployer wallet (WITHOUT 0x prefix is fine, with 0x also works)
# Use a FRESH test wallet — never reuse with mainnet
# Get free Sepolia ETH from: https://sepoliafaucet.com or https://sepolia-faucet.pk910.de
DEPLOYER_PRIVATE_KEY=0xYOUR_TEST_WALLET_PRIVATE_KEY_HERE

# Optional: for etherscan verification
# Get at: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
