{
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_API_URL": "https://major-api.jayeshgpt.tech/api/v1",
    "NEXT_PUBLIC_BASE_URL": "https://major-api.jayeshgpt.tech"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://major-api.jayeshgpt.tech/api/:path*"
    }
  ]
}
